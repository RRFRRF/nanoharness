{
  "name": "nanoclaw",
  "version": "1.2.21",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:agent-runner": "npm --prefix container/agent-runner run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "terminal": "node dist/index.js --terminal --terminal-log-level error",
    "terminal:logs": "node dist/index.js --terminal --terminal-log-view ink --terminal-log-level trace",
    "terminal:user": "node dist/index.js --terminal --terminal-log-level error",
    "terminal:dev": "tsx src/index.ts --terminal --terminal-log-level error",
    "terminal:logs:dev": "tsx src/index.ts --terminal --terminal-log-view ink --terminal-log-level trace",
    "terminal:user:dev": "tsx src/index.ts --terminal --terminal-log-level error",
    "typecheck": "tsc --noEmit",
    "test:core": "vitest run src/container-runner.test.ts src/group-queue.test.ts src/task-scheduler.test.ts src/terminal-channel.test.ts src/credential-proxy.test.ts src/db.test.ts",
    "test:refactor": "vitest run src/container-runner.test.ts src/container-runner-provider.test.ts src/credential-proxy.test.ts src/config-provider.test.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "verify:affected": "node scripts/verify-affected.mjs",
    "verify:refactor": "node scripts/verify-refactor.mjs",
    "smoke:container-build": "node scripts/smoke-container-build.mjs",
    "smoke:container-agent": "node scripts/smoke-container-agent.mjs",
    "verify:core": "node scripts/verify-core.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.2.4",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
